# Supabase — copia este archivo a .env.local y rellena con tus valores.
# Project Settings → API en el panel de Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Sin estas variables la app funciona en "modo demo" (datos de muestra,
# los formularios simulan el envío y no guardan nada).
